# Data: raw/interim/processed artifacts are never committed
data/raw/*
data/interim/*
data/processed/*
data/external/*
!data/**/.gitkeep

# Run outputs
outputs/checkpoints/*
outputs/figures/*
outputs/logs/*
outputs/reports/*
!outputs/**/.gitkeep

# Secrets
.env
*.key
